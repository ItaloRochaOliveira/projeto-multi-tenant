    "@types/jsonwebtoken": "9.0.6",
    "@types/multer": "^2.1.0",
    "@types/node": "20.14.2",
    "@types/pdfmake": "^0.3.2",
    "@types/uuid": "^9.0.8",
    "axios": "^1.7.7",
    "eslint": "^9.10.0",
    "globals": "^15.9.0",
    "husky": "9.1.6",
