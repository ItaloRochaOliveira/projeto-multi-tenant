    "dotenv": "16.4.5",
    "express": "4.19.2",
    "express-async-errors": "3.1.1",
    "jsonwebtoken": "9.0.2",
    "jspdf": "^2.5.1",
    "mysql2": "^3.11.0",
    "multer": "^2.1.1",
    "pdfmake": "^0.3.5",
    "reflect-metadata": "^0.2.2",
    "typeorm": "^0.3.20",
    "typeorm-model-generator": "^0.4.6",
    "uuid": "^9.0.1",
    "winston": "^3.19.0",
    "zod": "3.23.8"
