{
  "name": "multi-tenant",
  "version": "1.0.0",
  "description": "criação de uma api de gestão de um multi tenant para aprendizado",
  "main": "app.js",
  "scripts": {
    "start": "node build/server.js",
    "start:dev": "tsx watch src/server.ts",
    "build": "tsup src --out-dir build",
    "test": "echo \"Error: no test specified\" && exit 1",
    "test:locale": "tsx teste/local-api-runner.ts",
    "test:multi-tenant": "tsx teste/multi-tenant-isolation-runner.ts",
    "docker:rebuild-api": "docker compose build --no-cache api && docker compose up -d"
  },
