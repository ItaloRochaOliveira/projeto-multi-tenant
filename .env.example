# Copie para `.env` e ajuste (não commite segredos reais).
# Validação: `src/env/index.ts` (Zod).

# API
PORT=3006
ENV=dev

# JWT (mínimo 16 caracteres)
JWT_SECRET=dev_jwt_secret_change_me_16

# MySQL — app (TypeORM)
# Local (npm run start:dev): host 127.0.0.1 e porta exposta do MySQL (ex.: 3311)
# Docker Compose: use MYSQL_HOST=db e MYSQL_PORT=3306 (rede interna)
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=app
MYSQL_PASSWORD=changeme
MYSQL_DATABASE=multi_tenant

# MySQL — imagem oficial (Docker Compose: serviço `db`)
# Deve existir no `.env` para o contentor MySQL; alinhe com MYSQL_USER/MYSQL_PASSWORD se criar o mesmo utilizador.
MYSQL_ROOT_PASSWORD=changeme
